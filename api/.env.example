# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=sb_publishable_...                 # publishable key (RLS-respecting reads)
SUPABASE_SERVICE_ROLE_KEY=                      # server-only writes that bypass RLS
SUPABASE_JWT_SECRET=                            # for verifying user JWTs

# LLM providers (only set the ones you use)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Encryption key for stored BYOK secrets (32 url-safe bytes, base64)
SECRETS_MASTER_KEY=

# CORS
WEB_ORIGIN=http://localhost:3000
